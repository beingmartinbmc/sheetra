{
  "name": "pravaah",
  "version": "0.2.0",
  "description": "Production-grade Excel, CSV, and JSONL ingestion pipelines for Node.js.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "pravaah": "./dist/cli/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./cli": {
      "types": "./dist/cli/index.d.ts",
      "import": "./dist/cli/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "CONTRIBUTING.md",
    "LICENSE"
  ],
  "scripts": {
    "clean": "rm -rf dist",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "lint": "eslint \"src/**/*.ts\" \"test/**/*.ts\" \"benchmark/**/*.ts\"",
    "format": "prettier --write .",
    "benchmark": "tsx benchmark/streaming.ts",
    "benchmark:compare": "tsx benchmark/compare.ts",
    "benchmark:files": "tsx benchmark/files.ts",
    "benchmark:isolated": "tsx benchmark/isolated/index.ts",
    "benchmark:strong": "tsx benchmark/strong.ts",
    "prepublishOnly": "npm run clean && npm run lint && npm run typecheck && npm test && npm run build"
  },
  "keywords": [
    "excel",
    "xlsx",
    "csv",
    "streaming",
    "typescript",
    "etl",
    "spreadsheet"
  ],
  "author": "beingmartinbmc",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/beingmartinbmc/pravaah.git"
  },
  "bugs": {
    "url": "https://github.com/beingmartinbmc/pravaah/issues"
  },
  "homepage": "https://github.com/beingmartinbmc/pravaah#readme",
  "engines": {
    "node": ">=20"
  },
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "fflate": "^0.8.2"
  },
  "peerDependencies": {
    "xlsx": "^0.18.5"
  },
  "peerDependenciesMeta": {
    "xlsx": {
      "optional": true
    }
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^10.2.1",
    "prettier": "^3.8.3",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.0",
    "vitest": "^4.1.5",
    "xlsx": "^0.18.5"
  }
}
